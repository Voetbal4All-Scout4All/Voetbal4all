{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "framework": null,
    "rewrites": [
          {
                  "source": "/api/scout/(.*)",
                  "destination": "https://voetbal4all-backend-database.onrender.com/api/scout/$1"
          },
          {
                  "source": "/scout/(.*)",
                  "destination": "/scout/index.html"
          }
    ],
    "headers": [
          {
                  "source": "/scout/assets/(.*)",
                  "headers": [
                            { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
                  ]
          }
    ]
}
