{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "scout.voetbal4all.eu"
        }
      ],
      "destination": "/scout/login",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/scout/assets/img/(.*)",
      "destination": "/scout/assets/img/$1"
    },
    {
      "source": "/api/scout/(.*)",
      "destination": "https://voetbal4all-backend-database.onrender.com/api/scout/$1"
    },
    {
      "source": "/scout/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/scout",
      "destination": "/scout-index.html"
    },
    {
      "source": "/scout/(.*)",
      "destination": "/scout-index.html"
    }
  ],
  "headers": [
    {
      "source": "/scout/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}